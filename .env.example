# App
APP_NAME="Dude Payment Sharing System"
ENVIRONMENT=local
DEBUG=true
API_V1_PREFIX=/api/v1

# Security
# Generate a strong value before production:
# python -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=change-this-before-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=720
REMEMBER_USERNAME_DAYS=5

# CORS
BACKEND_CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:5500,http://localhost:5173,https://your-vercel-app.vercel.app

# MariaDB local example - XAMPP
DATABASE_URL=mysql+pymysql://root:2580@127.0.0.1:3306/dude_system

# Supabase PostgreSQL later example
# DATABASE_URL=postgresql+psycopg://postgres:YOUR_PASSWORD@db.YOUR_PROJECT.supabase.co:5432/postgres

# Supabase Storage later
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_STORAGE_BUCKET=payment-slips
